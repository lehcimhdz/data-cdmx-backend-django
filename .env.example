# Copia a .env y ajusta los valores
# En producción (EC2) estos valores los escribe Terraform en /opt/cdmx/.env

# Django
DJANGO_SECRET_KEY=cambia-esto-en-produccion
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Base de datos — desarrollo local
DB_NAME=cdmx
DB_USER=cdmx
DB_PASSWORD=cdmx
DB_HOST=localhost
DB_PORT=5432

# Base de datos — producción (RDS)
# Los valores los entrega Terraform vía `terraform output`
# DB_HOST=cdmx-postgres.xxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=cdmx
# DB_USER=cdmx
# DB_PASSWORD=<valor-seguro>

# Redis — producción (ElastiCache)
# REDIS_URL=redis://<elasticache-endpoint>:6379/0

# Sentry — dejar vacío para deshabilitar
SENTRY_DSN=
DJANGO_ENV=production
